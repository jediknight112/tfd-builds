{
  "name": "tfd-builds",
  "version": "1.0.0",
  "type": "module",
  "description": "The First Descendant Character Build Viewer",
  "main": "src/index.js",
  "scripts": {
    "predev": "node scripts/ensure-dist.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" --names \"FRONT,BACK\" --prefix-colors \"blue,magenta\" --kill-others",
    "dev:frontend": "vite",
    "dev:backend": "wrangler dev",
    "dev:worker": "npm run build && wrangler dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run format:check",
    "prepare": "husky"
  },
  "keywords": [
    "tfd",
    "builds",
    "gaming"
  ],
  "author": "",
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "lz-string": "^1.5.0"
  }
}
