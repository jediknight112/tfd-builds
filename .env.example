# TFD Build Viewer Configuration

# API base URL.
# Defaults to "/api/tfd" (the tfd-builds Worker's server-side proxy).
# Override only if you want the browser to talk directly to a tfd-cache
# instance during local dev — note that this exposes your API keys.
# VITE_API_BASE_URL=https://tfd-cache.jediknight112.com

# Default UI language. Users can override via the language selector.
VITE_LANGUAGE_CODE=en

# Feature Flags
VITE_ENABLE_BUILD_SHARING=false
VITE_ENABLE_ANALYTICS=false
